{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "ibuscribe backend",
      "runtimeExecutable": "venv/Scripts/uvicorn",
      "runtimeArgs": ["main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "port": 8000,
      "cwd": "backend"
    },
    {
      "name": "ibuscribe frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--host"],
      "port": 3000,
      "autoPort": true,
      "cwd": "frontend"
    }
  ]
}
